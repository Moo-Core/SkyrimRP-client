{
  "name": "skymp5-client",
  "version": "1.0.0",
  "license": "GPL-3.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "webpack",
    "watch": "webpack -w",
    "proto:gen": "node scripts/gen-proto.cjs",
    "proto:clean": "node -e \"const fs=require('fs'),p=require('path');for(const f of fs.readdirSync('src/proto/skyrimrp/v1')){if(f.endsWith('.ts'))fs.rmSync(p.join('src/proto/skyrimrp/v1',f))}\""
  },
  "devDependencies": {
    "bestzip": "^2.2.0",
    "ts-loader": "^9.2.6",
    "ts-proto": "^2.7.7",
    "tsc": "^2.0.3",
    "typescript": "^4.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^4.9.1",
    "webpack-shell-plugin-next": "^2.2.2"
  },
  "keywords": [
    "skyrim",
    "skyrim platform"
  ],
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@skyrim-platform/skyrim-platform": "2.8.0",
    "eventemitter3": "^5.0.1"
  }
}
